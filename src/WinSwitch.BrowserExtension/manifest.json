{
  "manifest_version": 3,
  "name": "WinSwitch Browser Bridge",
  "version": "1.0",
  "description": "将浏览器窗口/标签页信息发送给 WinSwitch 本地程序，实现精确窗口控制",
  "permissions": [
    "tabs",
    "windows",
    "nativeMessaging"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

<Window x:Class="WinSwitch.UI.Views.WindowPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="拾取窗口"
        Width="560" Height="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="选择要绑定的窗口：" Margin="0,0,0,8"/>

        <DataGrid Grid.Row="1"
                  Name="WindowsDataGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  HeadersVisibility="Column">

            <DataGrid.Columns>
                <DataGridTextColumn Header="进程名" Binding="{Binding ProcessName}" Width="120"/>
                <DataGridTextColumn Header="窗口标题" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="句柄" Binding="{Binding Handle}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Name="BtnRefresh" Content="刷新" Click="BtnRefresh_Click" MinWidth="80"/>
            <Button Content="确定" Click="BtnOk_Click" IsDefault="True" MinWidth="80"/>
            <Button Content="取消" Click="BtnCancel_Click" IsCancel="True" MinWidth="80"/>
        </StackPanel>
    </Grid>
</Window>

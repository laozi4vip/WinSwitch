<Window x:Class="WinSwitch.UI.Views.BossKeySettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="老板键设置"
        Width="400" Height="250"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 快捷键 -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="老板键" VerticalAlignment="Center"/>
        <TextBox Grid.Row="0" Grid.Column="1" Name="TxtBossKey" Margin="4"/>

        <!-- 隐藏模式 -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="隐藏模式" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="1" Grid.Column="1" Name="CmbBossKeyMode" Margin="4">
            <ComboBoxItem Content="仅隐藏窗口" Tag="1"/>
            <ComboBoxItem Content="隐藏窗口+任务栏图标" Tag="2"/>
            <ComboBoxItem Content="隐藏窗口+任务栏+Alt+Tab" Tag="3"/>
        </ComboBox>

        <!-- 说明 -->
        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                   Margin="0,8,0,0" Opacity="0.6" FontSize="11" TextWrapping="Wrap"
                   Text="提示: 模式3提供最完整的隐藏效果，但恢复时需要还原窗口样式。模式1最简单但隐藏效果最弱。"/>

        <!-- 按钮 -->
        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="确定" Click="BtnOk_Click" IsDefault="True" MinWidth="80"/>
            <Button Content="取消" Click="BtnCancel_Click" IsCancel="True" MinWidth="80"/>
        </StackPanel>
    </Grid>
</Window>

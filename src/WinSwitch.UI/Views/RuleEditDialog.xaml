<Window x:Class="WinSwitch.UI.Views.RuleEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑规则"
        Width="480" Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 规则名称 -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="规则名称" VerticalAlignment="Center"/>
        <TextBox Grid.Row="0" Grid.Column="1" Name="TxtName" Margin="4"/>

        <!-- 快捷键 -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="快捷键" VerticalAlignment="Center"/>
        <TextBox Grid.Row="1" Grid.Column="1" Name="TxtHotkey" Margin="4"
                 IsReadOnly="True" Focusable="True"/>
        <TextBlock Grid.Row="1" Grid.Column="1" Margin="4,28,4,0"
                   Text="点击输入框，按下组合键设置（如 Ctrl+A）" Opacity="0.5" FontSize="11"/>

        <!-- 匹配模式 -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="匹配模式" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="2" Grid.Column="1" Name="CmbMatchMode" Margin="4"
                  SelectionChanged="CmbMatchMode_SelectionChanged"/>

        <!-- 进程名 -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="进程名" VerticalAlignment="Center"/>
        <TextBox Grid.Row="3" Grid.Column="1" Name="TxtProcessName" Margin="4"/>

        <!-- 标题规则 -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="标题规则" VerticalAlignment="Center"
                   Name="LblTitlePattern"/>
        <TextBox Grid.Row="4" Grid.Column="1" Name="TxtTitlePattern" Margin="4"/>
      <TextBlock Grid.Row="4" Grid.Column="1" Margin="4,28,4,0" Text="包含模式支持分号分隔多关键词，如: Chrome;Edge" Opacity="0.5" FontSize="11"/>

        <!-- 标题匹配方式 -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="匹配方式" VerticalAlignment="Center"
                   Name="LblTitleMatchType"/>
        <ComboBox Grid.Row="5" Grid.Column="1" Name="CmbTitleMatchType" Margin="4"/>

        <!-- 老板键选项 -->
        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,0">
            <CheckBox Name="ChkBossKeyEnabled" Content="受老板键控制" IsChecked="True" Margin="4"/>
            <CheckBox Name="ChkHideTaskbar" Content="老板键时隐藏任务栏图标" IsChecked="True" Margin="4"/>
            <CheckBox Name="ChkHideAltTab" Content="老板键时从 Alt+Tab 隐藏" IsChecked="True" Margin="4"/>
        </StackPanel>

        <!-- 按钮 -->
        <StackPanel Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="确定" Click="BtnOk_Click" IsDefault="True" MinWidth="80"/>
            <Button Content="取消" Click="BtnCancel_Click" IsCancel="True" MinWidth="80"/>
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="WinSwitch.UI.Views.RuleEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑规则"
        Width="560" Height="Auto"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="110"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Row 0: 规则名称 -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="规则名称" VerticalAlignment="Center"/>
        <TextBox Grid.Row="0" Grid.Column="1" Name="TxtName" Margin="4" MinHeight="28"/>

        <!-- Row 1: 快捷键 -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="快捷键" VerticalAlignment="Center"/>
        <TextBox Grid.Row="1" Grid.Column="1" Name="TxtHotkey" Margin="4" IsReadOnly="True" Focusable="True" MinHeight="28"/>
        <TextBlock Grid.Row="2" Grid.Column="1" Margin="4,0,4,4" Text="点击上方输入框，按下组合键设置（如 Ctrl+A 或 F1-F12）" Opacity="0.5" FontSize="11"/>

        <!-- Row 3: 匹配模式 -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="匹配模式" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="3" Grid.Column="1" Name="CmbMatchMode" Margin="4" MinHeight="28" SelectionChanged="CmbMatchMode_SelectionChanged"/>

        <!-- Row 4: 进程名 -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="进程名" VerticalAlignment="Center" Name="LblProcessName"/>
        <TextBox Grid.Row="4" Grid.Column="1" Name="TxtProcessName" Margin="4" MinHeight="28"/>
        <TextBlock Grid.Row="4" Grid.Column="1" Name="LblProcessNameHint" Margin="4,32,4,0" Text="" Opacity="0.5" FontSize="11" TextWrapping="Wrap" Visibility="Collapsed"/>

        <!-- Row 5: 任务栏序号 -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="任务栏序号" VerticalAlignment="Center" Name="LblTaskbarSlot" Visibility="Collapsed"/>
        <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Name="PnlTaskbarSlot" Visibility="Collapsed">
            <TextBox Name="TxtTaskbarSlot" Margin="4" MinHeight="28" Width="60" TextAlignment="Center" Text="1"/>
            <TextBlock Margin="8,0,0,0" Text="序号 1-10 (对应 Win+1...Win+0)" Opacity="0.5" FontSize="11" VerticalAlignment="Center" Name="LblTaskbarSlotHint"/>
        </StackPanel>

        <!-- Row 6-7: 标题规则 -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="标题规则" VerticalAlignment="Center" Name="LblTitlePattern"/>
        <TextBlock Grid.Row="6" Grid.Column="1" Margin="4,0,4,0" Text="所有关键词都必须完全匹配（用分号分隔），如：Chrome;工作台 → 需同时匹配两者" Opacity="0.5" FontSize="11" Name="LblTitleHint" TextWrapping="Wrap"/>
        <TextBox Grid.Row="7" Grid.Column="1" Name="TxtTitlePattern" Margin="4" MinHeight="28" AcceptsReturn="False"/>

        <!-- Row 8: 标题匹配方式 -->
        <TextBlock Grid.Row="8" Grid.Column="0" Text="匹配方式" VerticalAlignment="Center" Name="LblTitleMatchType"/>
        <ComboBox Grid.Row="8" Grid.Column="1" Name="CmbTitleMatchType" Margin="4" MinHeight="28"/>

        <!-- Row 9: 浏览器匹配模式 -->
        <TextBlock Grid.Row="9" Grid.Column="0" Text="浏览器匹配" VerticalAlignment="Center" Name="LblBrowserMatch"/>
        <ComboBox Grid.Row="9" Grid.Column="1" Name="CmbBrowserMatchMode" Margin="4" MinHeight="28" SelectionChanged="CmbBrowserMatchMode_SelectionChanged"/>

        <!-- Row 10-11: URL 匹配规则 -->
        <TextBlock Grid.Row="10" Grid.Column="0" Text="URL规则" VerticalAlignment="Center" Name="LblUrlPattern"/>
        <TextBlock Grid.Row="10" Grid.Column="1" Margin="4,0,4,0" Text="浏览器标签页URL匹配规则（需安装浏览器扩展）" Opacity="0.5" FontSize="11" Name="LblUrlHint"/>
        <TextBox Grid.Row="11" Grid.Column="1" Name="TxtUrlPattern" Margin="4" MinHeight="28" AcceptsReturn="False"/>

        <!-- Row 12: URL 匹配方式 -->
        <TextBlock Grid.Row="12" Grid.Column="0" Text="URL匹配方式" VerticalAlignment="Center" Name="LblUrlMatchType"/>
        <ComboBox Grid.Row="12" Grid.Column="1" Name="CmbUrlMatchType" Margin="4" MinHeight="28"/>

        <!-- Row 13: 模式说明 -->
        <TextBlock Grid.Row="13" Grid.Column="0" Grid.ColumnSpan="2" Name="LblModeHint" Margin="4,8,4,4" Text="" Opacity="0.6" FontSize="12" TextWrapping="Wrap" Visibility="Collapsed"/>

        <!-- Row 14: 老板键选项 -->
        <StackPanel Grid.Row="14" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,0" Name="PnlBossKey">
            <CheckBox Name="ChkBossKeyEnabled" Content="受老板键控制" IsChecked="True" Margin="4"/>
            <CheckBox Name="ChkHideTaskbar" Content="老板键时隐藏任务栏图标" IsChecked="True" Margin="4"/>
            <CheckBox Name="ChkHideAltTab" Content="老板键时从 Alt+Tab 隐藏" IsChecked="True" Margin="4"/>
        </StackPanel>

        <!-- Row 15: 按钮 -->
        <StackPanel Grid.Row="15" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="确定" Click="BtnOk_Click" IsDefault="True" Width="80" Height="30" Margin="0,0,8,0"/>
            <Button Content="取消" Click="BtnCancel_Click" IsCancel="True" Width="80" Height="30"/>
        </StackPanel>
    </Grid>
</Window>